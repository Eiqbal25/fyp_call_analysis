[
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Terselamat pagi. Bank harapan dengan saya Amirul. Boleh saya bantu, encik?",
    "start": 0.0,
    "end": 4.44,
    "duration": 4.44
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Aku nak tahu kenapa ada tolak duit dari air kawan aku seratus sikit.",
    "start": 4.94,
    "end": 8.64,
    "duration": 3.7
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Orang ini pandai-pandai contoh tolak duit orang.",
    "start": 9.06,
    "end": 10.88,
    "duration": 1.82
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Harap bersabar, encik. Saya minta maaf atas kesultan ini.",
    "start": 11.6,
    "end": 15.24,
    "duration": 3.64
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Boleh saya dapatkan nomor kat pengenalan untuk saya makan?",
    "start": 15.68,
    "end": 18.12,
    "duration": 2.44
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Nak nomor kat pengenalan buat apa? Cek jelah nama apa, Johan.",
    "start": 18.64,
    "end": 21.5,
    "duration": 2.86
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Aku dah telefon banyak kali. Takkan tak ada rekod.",
    "start": 21.92,
    "end": 23.76,
    "duration": 1.84
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Maaf, Encik Johan. Prosedur keselamatan Bank memerlukan nomor kat pengenalan",
    "start": 24.28,
    "end": 28.62,
    "duration": 4.34
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "untuk kami buka profil Encik.",
    "start": 28.62,
    "end": 30.6,
    "duration": 1.98
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Menusahkan betul.",
    "start": 31.0,
    "end": 31.84,
    "duration": 0.84
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "890-2140-1553.",
    "start": 33.52,
    "end": 36.18,
    "duration": 2.66
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Cepat sikit.",
    "start": 36.8,
    "end": 37.24,
    "duration": 0.44
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Terima kasih, Encik Johan.",
    "start": 37.7,
    "end": 38.96,
    "duration": 1.26
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Sementara saya simak transaksi terakhir, Encik.",
    "start": 39.4,
    "end": 42.2,
    "duration": 2.8
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Jangan suhu aku tunggu lama-lama.",
    "start": 42.58,
    "end": 43.9,
    "duration": 1.32
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Aku ada banyak kerja lain nak buat.",
    "start": 44.22,
    "end": 45.46,
    "duration": 1.24
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Bukan nak layan bank orang.",
    "start": 45.76,
    "end": 46.68,
    "duration": 0.92
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Baik, Encik.",
    "start": 47.26,
    "end": 47.94,
    "duration": 0.68
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Saya nampak ada penulakan 100 rigit",
    "start": 48.3,
    "end": 50.64,
    "duration": 2.34
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "untuk charge tahunan kat credit, Encik.",
    "start": 50.64,
    "end": 52.72,
    "duration": 2.08
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Charge tahunan apa benda pula?",
    "start": 53.04,
    "end": 54.26,
    "duration": 1.22
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Aku dah guna kat ini 5 tahun.",
    "start": 54.7,
    "end": 56.08,
    "duration": 1.38
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Tak pernah ada charge tahunan.",
    "start": 56.32,
    "end": 57.38,
    "duration": 1.06
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Kau orang ini nak menipu ke?",
    "start": 57.38,
    "end": 58.76,
    "duration": 1.38
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Untuk maklumat, Encik,",
    "start": 59.28,
    "end": 60.46,
    "duration": 1.18
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "pengetualian charge tahunan hanya untuk tiga tahun pertama.",
    "start": 60.74,
    "end": 63.76,
    "duration": 3.02
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Bermula tahun ke empat, charge akan dikenakan.",
    "start": 64.18,
    "end": 66.62,
    "duration": 2.44
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Oh tak, kau!",
    "start": 67.2,
    "end": 67.94,
    "duration": 0.74
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Siapa yang cakap macam tu?",
    "start": 68.3,
    "end": 69.18,
    "duration": 0.88
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Masa aku reply dulu, agent korang cakap free semua hidup.",
    "start": 69.6,
    "end": 72.02,
    "duration": 2.42
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Saya faham ke keciwaan, Encik.",
    "start": 72.54,
    "end": 74.26,
    "duration": 1.72
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Saya boleh bantu hantar permohonan untuk membatalkan charge tersebut.",
    "start": 74.5,
    "end": 77.82,
    "duration": 3.32
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Tak payah nak hantar permohonan sangat.",
    "start": 78.36,
    "end": 79.72,
    "duration": 1.36
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Kau cancel je terus sekarang.",
    "start": 80.12,
    "end": 81.26,
    "duration": 1.14
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Kalau tak, aku tutup ekon agar ini juga.",
    "start": 81.52,
    "end": 83.28,
    "duration": 1.76
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Encik, proses pembatalan perlukan keleluisan pihak",
    "start": 83.8,
    "end": 86.96,
    "duration": 3.16
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Saya tidak boleh buat terus dari sistem saya.",
    "start": 87.7,
    "end": 89.9,
    "duration": 2.2
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Habis itu kau buat apa di situ? Angkat telefon je ke?",
    "start": 90.28,
    "end": 92.78,
    "duration": 2.5
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Panggil bos kau sekarang. Aku nak percakap dengan dia.",
    "start": 93.16,
    "end": 95.18,
    "duration": 2.02
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Baiklah, Cik. Saya akan sambungkan panggilan ini kepada pegawai atasan saya.",
    "start": 95.7,
    "end": 99.62,
    "duration": 3.92
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Mohon tunggu sebentar.",
    "start": 100.06,
    "end": 101.0,
    "duration": 0.94
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Sebab sikit. Jangan nak melinggal-linggalkan masa aku.",
    "start": 101.5,
    "end": 103.52,
    "duration": 2.02
  }
]
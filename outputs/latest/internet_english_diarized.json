    "end": 10.16,
    "duration": 4.86
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "I apologize for the inconvenience. Let me pull up your account. Can I get your account number?",
    "start": 10.74,
    "end": 15.3,
    "duration": 4.56
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",

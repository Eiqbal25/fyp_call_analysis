[
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Helo?",
    "start": 0.0,
    "end": 0.52,
    "duration": 0.52
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Hah, nak apa? Kuali khidmat pelanggan ni.",
    "start": 0.9,
    "end": 2.8,
    "duration": 1.9
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Selamat pagi.",
    "start": 3.28,
    "end": 3.94,
    "duration": 0.66
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Saya nak tanya pasal barang saya dah dua minggu tak sampai.",
    "start": 4.42,
    "end": 7.54,
    "duration": 3.12
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Status tulis dah hantar.",
    "start": 8.02,
    "end": 9.42,
    "duration": 1.4
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Dah tu? Kalau status tulis dah hantar, maknanya dah hantarlah. Takkan tu pun nak kenal aja.",
    "start": 9.74,
    "end": 14.64,
    "duration": 4.9,
    "text_corrected": true
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Masalahnya, saya tak terima apa-apa pun. Barang tu mahal kuat. Boleh tak tolong semak?",
    "start": 15.38,
    "end": 20.12,
    "duration": 4.74
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Bagilah nombor tracking tu. Nak semak macam mana kalau nombor pun tak pagi? Aduh, hai.",
    "start": 20.48,
    "end": 24.9,
    "duration": 4.42
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Nombor dia TR-99988.",
    "start": 24.9,
    "end": 29.14,
    "duration": 4.24
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Awak ni tak boleh kecakap iluk-iluk sikit, saya pelanggan tau.",
    "start": 29.68,
    "end": 32.8,
    "duration": 3.12
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Saya tengah banyak kerja ni, cik. Bukan cik sorang je pelanggan saya.",
    "start": 33.32,
    "end": 36.84,
    "duration": 3.52
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Okey, kejap. Saya tengok.",
    "start": 37.26,
    "end": 38.26,
    "duration": 1.0
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Ha ni sistem cakap kurier dah letak atas pagar rumahh cik.",
    "start": 38.68,
    "end": 42.0,
    "duration": 3.32,
    "text_corrected": true
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Pergilah cari kat luar ruh.",
    "start": 42.28,
    "end": 43.4,
    "duration": 1.12
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Saya dah cari satu rumah tak ada pun.",
    "start": 43.84,
    "end": 46.08,
    "duration": 2.24
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Hantar dia hantar salah rumah, kenapa?",
    "start": 46.48,
    "end": 48.32,
    "duration": 1.84,
    "text_corrected": true
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Alah saya tahu. Saya duduk pejabat. Bukan saya yang hantar barang tu.",
    "start": 48.82,
    "end": 51.94,
    "duration": 3.12,
    "text_corrected": true
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Pergi call Korea tu sendiri.",
    "start": 52.28,
    "end": 53.48,
    "duration": 1.2
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Kan ni platform tempat saya beli barang, kenapa pula saya yang kena call Korea,",
    "start": 53.48,
    "end": 57.62,
    "duration": 4.14
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "awak lah yang kena uruskan?",
    "start": 57.88,
    "end": 59.18,
    "duration": 1.3
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Anjik, tanggung jawab kita orang sampai barang tu keluar gudang je,",
    "start": 59.66,
    "end": 62.88,
    "duration": 3.22
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "lepas tu pandai-pandailah Korea.",
    "start": 63.22,
    "end": 64.56,
    "duration": 1.34
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Ini tak masuk akal.",
    "start": 65.08,
    "end": 66.38,
    "duration": 1.3
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Saya nak buat aduan pasal servis awak.",
    "start": 66.66,
    "end": 68.32,
    "duration": 1.66
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Bagi saya nama penuh awak sekarang.",
    "start": 68.66,
    "end": 70.22,
    "duration": 1.56
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Buatlah aduan.",
    "start": 70.72,
    "end": 71.26,
    "duration": 0.54
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Inak saya takut ke?",
    "start": 71.56,
    "end": 72.32,
    "duration": 0.76
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Nama saya Rizal.",
    "start": 72.6,
    "end": 73.36,
    "duration": 0.76
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Ada apa-apa lagi nak marah-marah ni?",
    "start": 73.7,
    "end": 75.1,
    "duration": 1.4
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Kurang aja betul.",
    "start": 75.5,
    "end": 76.44,
    "duration": 0.94
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Saya nak cakap dengan pengurus awak.",
    "start": 76.74,
    "end": 78.14,
    "duration": 1.4
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Saya tak nak berusian dengan orang macam awak.",
    "start": 78.4,
    "end": 80.28,
    "duration": 1.88
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Pengurus tak ada.",
    "start": 80.68,
    "end": 81.46,
    "duration": 0.78
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "dia sibuk nak tunggu tunggu lah tak nak tunggu letak je telefon tu",
    "start": 81.46,
    "end": 85.18,
    "duration": 3.72
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "dia adak betul punya perhimatan pelanggan",
    "start": 85.18,
    "end": 87.76,
    "duration": 2.58
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "iyalah iyalah bye",
    "start": 87.76,
    "end": 88.58,
    "duration": 0.82
  }
]
[
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Hah,",
    "start": 0.0,
    "end": 0.32,
    "duration": 0.32
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "selamat petang.",
    "start": 0.96,
    "end": 1.5,
    "duration": 0.54
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Terima kasih kerana menghubungi khidmat pelanggan Skyling Express.",
    "start": 1.9,
    "end": 4.64,
    "duration": 2.74
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Nama saya Fidoz. Boleh saya bantu encik hari ini?",
    "start": 5.42,
    "end": 7.92,
    "duration": 2.5
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Selamat petang, Fidoz.",
    "start": 8.34,
    "end": 9.58,
    "duration": 1.24
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Saya nak tanya pasal barang saya.",
    "start": 10.1,
    "end": 11.74,
    "duration": 1.64
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Nombor tracking MY-9920X.",
    "start": 12.5,
    "end": 16.34,
    "duration": 3.84,
    "text_corrected": true
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Dah tiga hari status di output delivery.",
    "start": 16.98,
    "end": 18.8,
    "duration": 1.82
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Tapi saya masih tak terima apa-apa.",
    "start": 19.12,
    "end": 20.94,
    "duration": 1.82
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Tidak, Mak. Af atas kesulitan tersebut encik.",
    "start": 21.6,
    "end": 24.16,
    "duration": 2.56
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Saya faham perasaan encik.",
    "start": 24.52,
    "end": 26.0,
    "duration": 1.48
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Sementara ya, biar saya semak dalam sistem kami,",
    "start": 26.54,
    "end": 28.66,
    "duration": 2.12
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Oh,",
    "start": 30.24,
    "end": 30.8,
    "duration": 0.56
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "saya dah nampak.",
    "start": 31.38,
    "end": 32.44,
    "duration": 1.06
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Tak mengikut rekod, rider kami dah hantar bangun semalam pada pukul dua putang.",
    "start": 32.98,
    "end": 37.94,
    "duration": 4.96
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Encik ada semak dengan ziran atau letak di dalam petiswan.",
    "start": 38.6,
    "end": 41.6,
    "duration": 3.0
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Dah semak, memang tak ada.",
    "start": 42.14,
    "end": 43.76,
    "duration": 1.62
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "CCTV rumah saya pun tak nampak ada motor lalu semalam.",
    "start": 44.4,
    "end": 47.3,
    "duration": 2.9
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Boleh tak awak pun hubungi rider itu untuk kepastian?",
    "start": 47.86,
    "end": 50.18,
    "duration": 2.32
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Sistem kami automati.",
    "start": 52.5,
    "end": 53.86,
    "duration": 1.36
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Kalau dia tulis delivery,",
    "start": 54.46,
    "end": 55.34,
    "duration": 0.88
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "makna dia dah sampai lah.",
    "start": 55.7,
    "end": 56.72,
    "duration": 1.02
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Itu kan sistem nak dipiklock.",
    "start": 56.72,
    "end": 58.88,
    "duration": 2.16
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Saya bukan kata sistem itu.",
    "start": 59.34,
    "end": 60.84,
    "duration": 1.5
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Tapi mungkin Raido itu salah hantar rumah.",
    "start": 61.4,
    "end": 63.4,
    "duration": 2.0
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Kulunglah cek balik sebab barang itu banyak.",
    "start": 64.04,
    "end": 66.02,
    "duration": 1.98
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Cik ini tak faham bahasa.",
    "start": 68.9,
    "end": 70.32,
    "duration": 1.42
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Aku dah cakap dah sampai. Sampai lah.",
    "start": 70.7,
    "end": 72.7,
    "duration": 2.0
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Kau ingat aku ada masa nak layan drama orang yang bilang kau ini.",
    "start": 73.32,
    "end": 76.06,
    "duration": 2.74
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "kenapa aku buat dukau bahasa macam ini?",
    "start": 77.24,
    "end": 78.98,
    "duration": 1.74
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Saya bercakap dengan cara baik ya.",
    "start": 79.58,
    "end": 81.14,
    "duration": 1.56
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Saya nak bercakap dengan pengurus awak sekarang.",
    "start": 81.76,
    "end": 83.54,
    "duration": 1.78
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Uuh, Ros.",
    "start": 84.64,
    "end": 85.32,
    "duration": 0.68
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Tak yuk nak beranggan.",
    "start": 85.78,
    "end": 86.84,
    "duration": 1.06
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Kau ingat kau siapa?",
    "start": 87.2,
    "end": 88.08,
    "duration": 0.88
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Stakek beranggan, macam tu pun nak bising-bising.",
    "start": 88.58,
    "end": 90.58,
    "duration": 2.0
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Kalau kawasan kakak pandai sangat, lain kali kegiam bising-bising kat budang.",
    "start": 91.0,
    "end": 93.98,
    "duration": 2.98
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Uyau, minum mokkul aku kat petang.",
    "start": 94.4,
    "end": 95.9,
    "duration": 1.5
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Saya akan buat riput tentang peranggan yang wok ni.",
    "start": 96.44,
    "end": 98.58,
    "duration": 2.14
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Pegilah, rikut. Ada kesaw.",
    "start": 99.14,
    "end": 101.14,
    "duration": 2.0
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Dahlah, malah ilmu layan orang -orang cikgu ni.",
    "start": 101.58,
    "end": 103.3,
    "duration": 1.72
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Cikaknya kerja lain lah daripada kacau orang.",
    "start": 103.68,
    "end": 105.2,
    "duration": 1.52
  }
]
[
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Samap petang, pusat bantu makan sini,",
    "start": 0.0,
    "end": 2.2,
    "duration": 2.2,
    "text_corrected": true
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "saya cik.",
    "start": 2.6,
    "end": 3.04,
    "duration": 0.44
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Boleh saya bantu, cik?",
    "start": 3.52,
    "end": 4.62,
    "duration": 1.1
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Hello, cik.",
    "start": 5.16,
    "end": 5.76,
    "duration": 0.6
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Saya nak tanya pasal pesanan saya tadi.",
    "start": 6.18,
    "end": 8.08,
    "duration": 1.9
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Saya baru perasan ada barang yang tertinggal dalam plastik ini.",
    "start": 8.56,
    "end": 11.42,
    "duration": 2.86
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Minta maaf atas kesulitan tersebut, cik. Boleh saya dapatkan nombor pesanan cik untuk saya buat semakkan dalam sistem?",
    "start": 11.96,
    "end": 18.28,
    "duration": 6.32
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Nombo dia MS8821.",
    "start": 18.28,
    "end": 21.98,
    "duration": 3.7
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Saya pesan set nasi lemak ayam berempah dengan air sirap. Tapi ayamnya tak ada.",
    "start": 22.58,
    "end": 27.5,
    "duration": 4.92
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Nasi dengan sambal saja ada.",
    "start": 27.94,
    "end": 29.48,
    "duration": 1.54
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Macam mana nak makan macam ni?",
    "start": 29.96,
    "end": 31.26,
    "duration": 1.3
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Saya faham perasaan encik. Saya pun akan kecewa kalau jadi macam ni.",
    "start": 31.86,
    "end": 35.84,
    "duration": 3.98,
    "text_corrected": true
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Berdasarkan rekod pesanan encik memang sepatutnya ada ayam.",
    "start": 36.42,
    "end": 39.58,
    "duration": 3.16,
    "text_corrected": true
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Encik nak saya pulangkan duit, refund untuk bahagian ayam itu atau encik nak bauci untuk pesanan akan datang.",
    "start": 40.02,
    "end": 46.14,
    "duration": 6.12
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Kalau boleh, saya nak refund sahajalah. Sebab saya dah lapar sangat ni, kena beli makanan lain pula nanti.",
    "start": 46.14,
    "end": 52.22,
    "duration": 6.08
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Baiklah. Saya akan uruskan proses bayaran balik setemerta.",
    "start": 52.86,
    "end": 56.16,
    "duration": 3.3
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Proses ini akan mengambil masa dalam 24 jam untuk masuk semula ke dalam e-wallet encik.",
    "start": 56.6,
    "end": 61.14,
    "duration": 4.54,
    "text_corrected": true
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Okeylah. Kalau macam tu,",
    "start": 61.84,
    "end": 63.04,
    "duration": 1.2
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "harap lepas ni pihak restoran lebih peka lah ya. Jangan cuai sangat bungkus makanan.",
    "start": 63.48,
    "end": 67.8,
    "duration": 4.32
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Betul encik. Kami akan hantar maklum balas tegas kepada pihak restoran tesebut.",
    "start": 68.38,
    "end": 72.6,
    "duration": 4.22,
    "text_corrected": true
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Ada apa-apa lagi yang boleh saya bantu?",
    "start": 73.08,
    "end": 74.64,
    "duration": 1.56
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Tak ada dah. Itu saja.",
    "start": 74.64,
    "end": 76.32,
    "duration": 1.68
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Terima kasih, Ya.",
    "start": 76.68,
    "end": 77.34,
    "duration": 0.66,
    "text_corrected": true
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Sama-sama, Cik. Terima kasih kerana menghubungi kami.",
    "start": 77.82,
    "end": 80.24,
    "duration": 2.42
  }
]
[
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Thank you for calling Global Connect Premium Support.",
    "start": 0.0,
    "end": 3.1,
    "duration": 3.1
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "My name is Marcus.",
    "start": 3.7,
    "end": 4.56,
    "duration": 0.86
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "To whom do I have the pleasure of speaking today?",
    "start": 5.06,
    "end": 6.9,
    "duration": 1.84
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Hi, Marcus.",
    "start": 7.76,
    "end": 8.58,
    "duration": 0.82
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "This is Sarah Jenkins.",
    "start": 8.98,
    "end": 9.88,
    "duration": 0.9
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "I'm calling because I've noticed a double charge on my credit card statement this morning for my monthly subscription.",
    "start": 10.54,
    "end": 15.54,
    "duration": 5.0
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "I'm very sorry to hear that, Ms. Jenkins.",
    "start": 16.48,
    "end": 18.74,
    "duration": 2.26
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "I certainly understand how frustrating unexpected charges can be.",
    "start": 19.2,
    "end": 23.08,
    "duration": 3.88
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Let me pull up your account profile.",
    "start": 23.48,
    "end": 24.9,
    "duration": 1.42
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Could you please verify the last four digits of the card on file?",
    "start": 25.56,
    "end": 28.42,
    "duration": 2.86
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Sure, it's 4492.",
    "start": 29.06,
    "end": 31.86,
    "duration": 2.8
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Just a moment while the system refreshes.",
    "start": 33.14,
    "end": 36.08,
    "duration": 2.94
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Okay,",
    "start": 38.1,
    "end": 38.7,
    "duration": 0.6
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "I see the two charges are $45.",
    "start": 39.38,
    "end": 41.2,
    "duration": 1.82
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Looks like the first one was a system-generated renewal and the second was a manual trigger.",
    "start": 42.44,
    "end": 48.2,
    "duration": 5.76
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Oh, that's strange.",
    "start": 49.02,
    "end": 50.66,
    "duration": 1.64
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "I didn't manually trigger anything.",
    "start": 51.38,
    "end": 53.32,
    "duration": 1.94
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Can we get that second one refunded today?",
    "start": 53.98,
    "end": 56.06,
    "duration": 2.08
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Well, looking at the logs,",
    "start": 57.48,
    "end": 59.34,
    "duration": 1.86
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "the request came from your IP address, Ms. Jenkins.",
    "start": 59.82,
    "end": 62.48,
    "duration": 2.66
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Our policy generally states that manual overrides are non-refundable.",
    "start": 63.34,
    "end": 67.16,
    "duration": 3.82
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Wait,",
    "start": 67.8,
    "end": 68.22,
    "duration": 0.42
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "I'm sorry?",
    "start": 68.66,
    "end": 69.48,
    "duration": 0.82
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "I definitely didn't do that.",
    "start": 70.12,
    "end": 71.7,
    "duration": 1.58
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "I was asleep at 3am when that charge went through.",
    "start": 72.08,
    "end": 74.76,
    "duration": 2.68
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Is there a supervisor I could talk to?",
    "start": 75.34,
    "end": 77.04,
    "duration": 1.7
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Look,",
    "start": 78.16,
    "end": 78.7,
    "duration": 0.54
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Sarah, a supervisor is going to tell you the exact same thing I just did.",
    "start": 79.3,
    "end": 82.96,
    "duration": 3.66
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "You think I'm just making this up for fun?",
    "start": 83.44,
    "end": 85.5,
    "duration": 2.06
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Excuse me?",
    "start": 86.36,
    "end": 87.28,
    "duration": 0.92
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "I'm just asking for a correction on a mistake your system made.",
    "start": 87.74,
    "end": 90.78,
    "duration": 3.04
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "There's no need for that tone.",
    "start": 91.18,
    "end": 92.76,
    "duration": 1.58
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "My tone?",
    "start": 93.58,
    "end": 94.54,
    "duration": 0.96
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Honestly, I'm tired of people calling in and playing dumb about their own mistakes.",
    "start": 95.72,
    "end": 99.82,
    "duration": 4.1
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "It's 45 dollars.",
    "start": 100.66,
    "end": 102.04,
    "duration": 1.38
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "If you're that desperate for the money, maybe you shouldn't have a premium subscription in the first place.",
    "start": 102.84,
    "end": 106.94,
    "duration": 4.1
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "I do not believe you just said that.",
    "start": 107.6,
    "end": 109.86,
    "duration": 2.26
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Giving your employee ID number right now.",
    "start": 109.86,
    "end": 112.4,
    "duration": 2.54
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "How about you?",
    "start": 112.96,
    "end": 114.04,
    "duration": 1.08
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "How about you just hang up and stop wasting my time?",
    "start": 114.72,
    "end": 117.28,
    "duration": 2.56
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "I've got actual customers with real problems.",
    "start": 117.88,
    "end": 120.08,
    "duration": 2.2
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Bye, Sarah.",
    "start": 121.04,
    "end": 121.84,
    "duration": 0.8
  }
]
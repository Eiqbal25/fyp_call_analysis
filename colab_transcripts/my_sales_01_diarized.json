[
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Selamat petang. Assalamualaikum Encik Hazik. Saya Syahrul dari Hydro Pure Malaysia. Saya harap Encik sihat hari ini.",
    "start": 0.0,
    "end": 6.5,
    "duration": 6.5
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Waalaikumsalam Encik Syahrul.",
    "start": 7.1,
    "end": 8.4,
    "duration": 1.3
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Ya, saya sihat Alhamdulillah. Ada apa ya? Hubungi saya petang -petang begini?",
    "start": 8.76,
    "end": 12.54,
    "duration": 3.78
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Begini Encik Hazik. Pertama sekali, kami ingin mengucapkan terima kasih kerana Encik telah menjadi pelanggan setia penapis udara kami selama dua tahun.",
    "start": 12.82,
    "end": 21.48,
    "duration": 8.66
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Sila jangan risau. Saya hubungi ini bukan untuk cas apa-apa bayaran, tetapi untuk berkongsi satu ganjaran eksklusif sempena bulan penghargaan pelanggan.",
    "start": 21.48,
    "end": 31.12,
    "duration": 9.64
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Oh,",
    "start": 31.38,
    "end": 31.8,
    "duration": 0.42
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "ganjaran apa itu ya? Saya ingatkan fasal servis penapis udara tadi.",
    "start": 32.26,
    "end": 36.5,
    "duration": 4.24
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Pakaj promosi baharukah?",
    "start": 36.9,
    "end": 38.48,
    "duration": 1.58
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Betul Encik Hazik.",
    "start": 38.62,
    "end": 39.74,
    "duration": 1.12
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Berdasarkan profil kesetiaan Encik, pihak pengurusan telah memilih Encik untuk menerima tawaran rebate khas sebanyak 40 % bagi pelancaran produk terbaharu kami,",
    "start": 40.12,
    "end": 50.3,
    "duration": 10.18
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "iaitu Hydro Pure Smart Purifier,",
    "start": 50.3,
    "end": 52.72,
    "duration": 2.42
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "penapis air pintar dengan fungsi pensterilan UV otomatik.",
    "start": 53.08,
    "end": 56.9,
    "duration": 3.82
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Kebetulan pula,",
    "start": 57.28,
    "end": 58.1,
    "duration": 0.82
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "memang saya dan isteri ada terfikir nak pasang penapis air kat rumah baru kami bulan depan.",
    "start": 58.5,
    "end": 63.06,
    "duration": 4.56
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Tapi itulah, sekarang ni banyak sangat jenama kat luar sana. Apa yang beza sangat penapis air pintar syarikat awak ni dengan jenama lain?",
    "start": 63.26,
    "end": 71.26,
    "duration": 8.0
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Soalan yang sangat bagus Encik Hazik.",
    "start": 71.6,
    "end": 73.68,
    "duration": 2.08
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Model pintar terbaharu ini dilengkapi dengan teknologi ekosensor yang menjimatkan elektrik sehingga 30%.",
    "start": 73.68,
    "end": 80.96,
    "duration": 7.28
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Paling penting,",
    "start": 80.96,
    "end": 82.18,
    "duration": 1.22
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "ia mempunyai reka bentuk yang sangat kompak dan minimalis.",
    "start": 82.56,
    "end": 85.8,
    "duration": 3.24
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Jadi ia tidak akan memakan ruang yang banyak di dapur rumah baru Encik nanti.",
    "start": 85.98,
    "end": 89.64,
    "duration": 3.66
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Hmm,",
    "start": 90.18,
    "end": 90.36,
    "duration": 0.18
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "jimat elektrik dan kompak ya? Menarik juga tu.",
    "start": 91.04,
    "end": 93.82,
    "duration": 2.78
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Sebab dapur rumah baru saya tu reka bentuknya modern, lurus.",
    "start": 93.98,
    "end": 97.44,
    "duration": 3.46
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Memang tak luas sangat.",
    "start": 97.6,
    "end": 98.76,
    "duration": 1.16
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Berapa ya komitmen bulanan kalau saya ambil pelan sewa beli?",
    "start": 99.2,
    "end": 102.26,
    "duration": 3.06
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Untuk harga pasaran biasa,",
    "start": 102.26,
    "end": 104.22,
    "duration": 1.96
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "komitmen bulanan adalah RM110.",
    "start": 104.66,
    "end": 106.62,
    "duration": 1.96
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Tetapi khas untuk Encik Hazik sebagai pelanggan VIP kami,",
    "start": 107.16,
    "end": 110.56,
    "duration": 3.4
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "dengan ribit 40 % tadi,",
    "start": 110.74,
    "end": 112.84,
    "duration": 2.1
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Encik cuma perlu bayar RM65 sahaja sebulan.",
    "start": 113.26,
    "end": 116.46,
    "duration": 3.2
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Harga ini sudah termasuk servis penukaran penapis percuma setiap 4 bulan",
    "start": 116.8,
    "end": 120.78,
    "duration": 3.98
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "dan jaminan penuh sepanjang tempoh kontrak.",
    "start": 120.78,
    "end": 123.4,
    "duration": 2.62
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Bia betul. RM65 sahaja sebulan.",
    "start": 123.64,
    "end": 126.82,
    "duration": 3.18
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Jarak harganya agak jauh berbanding harga asal ya.",
    "start": 127.24,
    "end": 129.94,
    "duration": 2.7
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Tapi saya kena berbincang dengan isteri saya dululah untuk pemilihan warna dan lokasi pemasangan.",
    "start": 129.94,
    "end": 135.3,
    "duration": 5.36
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Sila ambil masa, Encik.",
    "start": 135.56,
    "end": 136.92,
    "duration": 1.36
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Berbincang dengan isteri adalah perkara yang sangat penting.",
    "start": 137.14,
    "end": 139.86,
    "duration": 2.72
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Untuk memudahkan perancangan Encik berdua,",
    "start": 140.12,
    "end": 142.3,
    "duration": 2.18
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "apa kata saya hantarkan seorang pakar konsultan kami ke rumah Encik Sabtu ini",
    "start": 142.64,
    "end": 146.72,
    "duration": 4.08
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "untuk tunjukkan demo produk secara ringkas.",
    "start": 146.72,
    "end": 149.34,
    "duration": 2.62
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Encik boleh tengok sendiri saiz sebenar dan pilihan warna,",
    "start": 149.52,
    "end": 152.44,
    "duration": 2.92
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "tanpa sebarang komitmen bayaran pun.",
    "start": 152.56,
    "end": 154.6,
    "duration": 2.04
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Kalau macam tu, bagus juga.",
    "start": 154.96,
    "end": 156.34,
    "duration": 1.38
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Hari Sabtu petang dalam pukul 3 petang, kami berdua ada di rumah baru untuk kemas barang.",
    "start": 156.34,
    "end": 161.64,
    "duration": 5.3
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Awak boleh hantar konsultan datang waktu itu ya?",
    "start": 161.96,
    "end": 164.08,
    "duration": 2.12
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Baik Encik Hazik.",
    "start": 164.28,
    "end": 165.14,
    "duration": 0.86
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Saya dah jadualkan slot janji temu untuk hari Sabtu ini jam 3 petang.",
    "start": 165.36,
    "end": 169.16,
    "duration": 3.8
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Konsultan kami akan hubungi Encik terlebih dahulu sebelum datang.",
    "start": 169.58,
    "end": 172.72,
    "duration": 3.14
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Terima kasih banyak atas masa Encik dan tahniah atas rumah baru.",
    "start": 173.04,
    "end": 176.36,
    "duration": 3.32
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Selamat petang.",
    "start": 176.66,
    "end": 177.32,
    "duration": 0.66
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Sama-sama Encik Syarul.",
    "start": 177.32,
    "end": 178.66,
    "duration": 1.34
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Terima kasih kembali atas tawaran hebat ini.",
    "start": 178.84,
    "end": 180.84,
    "duration": 2.0
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Kita jumpa hari Sabtu nanti.",
    "start": 181.22,
    "end": 182.4,
    "duration": 1.18
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Assalamualaikum.",
    "start": 182.74,
    "end": 183.3,
    "duration": 0.56
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Waalaikumsalam warahmatullahi ta'ala wabarakatuh.",
    "start": 183.98,
    "end": 185.98,
    "duration": 2.0
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Terima kasih Encik Hazik.",
    "start": 186.22,
    "end": 187.2,
    "duration": 0.98
  }
]
[
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Selamat petang. Terima kasih kerana menghubungi Telco Line Care.",
    "start": 0.0,
    "end": 3.6,
    "duration": 3.6
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Nama saya Imran. Ada apa-apa yang boleh saya bantu uruskan hari ini?",
    "start": 3.92,
    "end": 7.78,
    "duration": 3.86
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Selamat petang, Encik Imran. Saya harap Encik sihat.",
    "start": 8.1,
    "end": 11.02,
    "duration": 2.92
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Saya nak tanya sedikit fasil akaun saya bulan ini.",
    "start": 11.5,
    "end": 14.2,
    "duration": 2.7
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Biasanya bil saya cuma RM60 sahaja setiap bulan.",
    "start": 14.5,
    "end": 17.46,
    "duration": 2.96
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Tapi kali ini saya tengok dalam aplikasi naik sampai RM140.",
    "start": 17.68,
    "end": 21.58,
    "duration": 3.9
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Boleh tolong semakkan kalau ada kesilapan sistem.",
    "start": 22.16,
    "end": 24.66,
    "duration": 2.5
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Tak ada silapnya tu, Encik.",
    "start": 26.32,
    "end": 28.12,
    "duration": 1.8
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Sistem kami dilaraskan secara otomatik.",
    "start": 28.12,
    "end": 30.9,
    "duration": 2.78
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Jadi memang mustahil untuk salah kira.",
    "start": 31.06,
    "end": 33.24,
    "duration": 2.18
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "RM140 tu maksudnya Encik ada guna data roaming",
    "start": 34.2,
    "end": 37.3,
    "duration": 3.1
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "atau langganan pihak ketiga lah tu masa pergi bercuti hari tu.",
    "start": 37.3,
    "end": 40.7,
    "duration": 3.4
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Pihak kami cuma cas apa yang telefon Encik guna sahaja.",
    "start": 41.3,
    "end": 44.66,
    "duration": 3.36
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Oh, bercuti keluar negara.",
    "start": 45.26,
    "end": 46.76,
    "duration": 1.5
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Tapi Encik, sepanjang dua bulan lepas,",
    "start": 47.18,
    "end": 49.42,
    "duration": 2.24
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "saya memang tak ada keluar dari kawasan Kuala Rumpur pun.",
    "start": 49.58,
    "end": 52.38,
    "duration": 2.8
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Apatah lagi luar negara.",
    "start": 52.58,
    "end": 53.82,
    "duration": 1.24
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Boleh saya tahu tarikh atau butiran terperinci data roaming tu digunakan?",
    "start": 54.04,
    "end": 57.96,
    "duration": 3.92
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Manalah tahu sistem tersalah letak cas bawah nombor akaun saya.",
    "start": 58.12,
    "end": 61.42,
    "duration": 3.3
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Eh, mana boleh salah?",
    "start": 62.0,
    "end": 63.52,
    "duration": 1.52
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Encik ingat sistem syarikat gergasi macam kami ni bodoh sangat ke",
    "start": 63.98,
    "end": 67.84,
    "duration": 3.86
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "sampai boleh sesuka hati tukai akaun orang?",
    "start": 67.84,
    "end": 70.12,
    "duration": 2.28
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Tak payah nak petikaikan sistem lah.",
    "start": 70.76,
    "end": 72.64,
    "duration": 1.88
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Dah kalau dalam rekod komputer tulis ada guna,",
    "start": 73.18,
    "end": 75.74,
    "duration": 2.56
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "maksudnya Encik yang gunalah tu.",
    "start": 75.98,
    "end": 77.88,
    "duration": 1.9
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Takkanlah hantu pula yang curik-curik guna telefon Encik kot.",
    "start": 78.48,
    "end": 81.2,
    "duration": 2.72
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Encik Imran, tolong jaga bahasa Encik ya.",
    "start": 81.6,
    "end": 84.22,
    "duration": 2.62
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Saya tanya elok-elok sebagai pelanggan sedia ada.",
    "start": 84.22,
    "end": 86.88,
    "duration": 2.66
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Dan saya rasa saya berhak untuk tahu butiran bil saya sendiri.",
    "start": 87.06,
    "end": 90.12,
    "duration": 3.06
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Saya cuba minta penjelasan yang jelas sahaja.",
    "start": 90.4,
    "end": 92.58,
    "duration": 2.18
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Tidak perlu sampai menyindir saya seperti itu.",
    "start": 92.76,
    "end": 94.66,
    "duration": 1.9
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Penjelasan apa lagi, Encik?",
    "start": 95.3,
    "end": 96.92,
    "duration": 1.62
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Saya dah bagitahu kan?",
    "start": 97.26,
    "end": 98.3,
    "duration": 1.04
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Dalam sistem, tertera cas tusah.",
    "start": 98.6,
    "end": 100.64,
    "duration": 2.04
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Kalau Encik sendiri tak tahu apa yang Encik langgan",
    "start": 100.84,
    "end": 103.76,
    "duration": 2.92
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "atau anak-anak Encik ada main telefon sampai tertekan iklan,",
    "start": 103.76,
    "end": 107.02,
    "duration": 3.26
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "itu bukan salah kamilah.",
    "start": 107.2,
    "end": 108.8,
    "duration": 1.6
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "kami tak ada masa nak pantau aktiviti harian telefon Encik satu persatu.",
    "start": 109.4,
    "end": 113.04,
    "duration": 3.64
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Encik Imran, saya tinggal seorang diri",
    "start": 113.4,
    "end": 115.96,
    "duration": 2.56
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "dan tidak ada anak kecil yang main telefon saya, Encik.",
    "start": 115.96,
    "end": 118.74,
    "duration": 2.78
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Memandangkan Encik Enggan membantu saya menyemak butiran ini dengan betul,",
    "start": 119.08,
    "end": 122.72,
    "duration": 3.64
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "tolong pas talian ini kepada pengurus",
    "start": 123.2,
    "end": 125.14,
    "duration": 1.94
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "atau supervisor Encik sekarang juga.",
    "start": 125.14,
    "end": 126.9,
    "duration": 1.76
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Saya mahu bercakap dengan pihak atasan yang lebih profesional.",
    "start": 127.1,
    "end": 130.04,
    "duration": 2.94
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Hmph,",
    "start": 130.9,
    "end": 131.5,
    "duration": 0.6
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "supervisor saya pun tak ada masalah",
    "start": 132.16,
    "end": 133.6,
    "duration": 1.44
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "nak layan benda remeh-temeh macam ni.",
    "start": 133.6,
    "end": 135.18,
    "duration": 1.58
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "ingat manajer kami duduk kat pejabat sahaja-sahaja tunggu panggilan Encik ke?",
    "start": 135.18,
    "end": 138.92,
    "duration": 3.74
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Bil dah keluar dalam sistem,",
    "start": 139.42,
    "end": 140.82,
    "duration": 1.4
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "maksudnya Encik wagit bayar je lah.",
    "start": 141.06,
    "end": 142.96,
    "duration": 1.9
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Tak payah nak banyak songih sangat sampai nak panggil manajer bagai.",
    "start": 143.4,
    "end": 146.5,
    "duration": 3.1
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Saya benar-benar terkejut dengan layanan Encik hari ni.",
    "start": 146.82,
    "end": 149.42,
    "duration": 2.6
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Ini bukan cara perkhidmatan korporat dikendalikan.",
    "start": 149.72,
    "end": 152.02,
    "duration": 2.3
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Sila berikan nama penuh Encik",
    "start": 152.58,
    "end": 153.86,
    "duration": 1.28
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "dan juga nombor ID pekerja Encik sekarang.",
    "start": 153.86,
    "end": 155.82,
    "duration": 1.96
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Saya akan buat laporan rasmi terus ke ibu pejabat",
    "start": 156.12,
    "end": 158.48,
    "duration": 2.36
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "dan juga aduan ke SKMM.",
    "start": 158.48,
    "end": 159.84,
    "duration": 1.36
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Hmph,",
    "start": 160.64,
    "end": 161.16,
    "duration": 0.52
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "aduh lah aduh.",
    "start": 161.52,
    "end": 162.5,
    "duration": 0.98
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Ingat saya takut ke dengan ugutan macam tu?",
    "start": 162.84,
    "end": 165.06,
    "duration": 2.22
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Setakat nak lapor ke SKMM,",
    "start": 165.7,
    "end": 167.28,
    "duration": 1.58
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "beribu-ribu orang dah buatlah Encik.",
    "start": 167.8,
    "end": 169.6,
    "duration": 1.8
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Tak ada kesan apa pun dekat saya.",
    "start": 169.78,
    "end": 171.14,
    "duration": 1.36
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Nama saya Imran.",
    "start": 171.7,
    "end": 173.1,
    "duration": 1.4
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Eja betul-betul ya.",
    "start": 173.38,
    "end": 174.18,
    "duration": 0.8
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "ID pekerja saya tak payah tahu.",
    "start": 174.66,
    "end": 176.28,
    "duration": 1.62
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Bukan urusan Encik pun.",
    "start": 176.54,
    "end": 177.74,
    "duration": 1.2
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Baik Encik Imran.",
    "start": 178.36,
    "end": 179.22,
    "duration": 0.86
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Perbualan ini sedang dirakam oleh sistem Encik sendiri",
    "start": 179.44,
    "end": 182.26,
    "duration": 2.82
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "dan saya pasti pihak pengurusan tertinggi",
    "start": 182.26,
    "end": 184.52,
    "duration": 2.26
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "tidak akan bertoleransi dengan sikap biadab sebegini terhadap pelanggan.",
    "start": 184.52,
    "end": 187.84,
    "duration": 3.32
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Terima kasih kerana tidak menyelesaikan masalah saya.",
    "start": 188.18,
    "end": 190.56,
    "duration": 2.38
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Saya akan gunakan saluran lain.",
    "start": 190.82,
    "end": 192.28,
    "duration": 1.46
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Ada saya kisah pasal rakaman.",
    "start": 192.84,
    "end": 194.32,
    "duration": 1.48
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Lagipun malaslah saya nak bazir masa",
    "start": 195.04,
    "end": 196.88,
    "duration": 1.84
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "melayan pelanggan yang tak faham bahasa macam Encik ni.",
    "start": 196.88,
    "end": 199.1,
    "duration": 2.22
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "Menyemak petang saya je.",
    "start": 199.6,
    "end": 200.74,
    "duration": 1.14
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Dahlah,",
    "start": 201.24,
    "end": 201.58,
    "duration": 0.34
  },
  {
    "speaker_id": 0,
    "speaker_raw": "SPEAKER_0",
    "text": "bayar je bil tu kalau tak nak land kena sekat.",
    "start": 201.94,
    "end": 203.86,
    "duration": 1.92
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Bye.",
    "start": 204.2,
    "end": 204.42,
    "duration": 0.22
  },
  {
    "speaker_id": 1,
    "speaker_raw": "SPEAKER_1",
    "text": "Terima kasih kerana menonton!",
    "start": 204.42,
    "end": 204.54,
    "duration": 0.12
  }
]